_config_version: 33

model:
  provider: ${LLM_PROVIDER}
  default: ${LLM_MODEL}
  max_tokens: 350

agent:
  max_turns: 24
  verbose: false
  reasoning_effort: low

display:
  compact: true
  show_reasoning: false
  streaming: false
  interim_assistant_messages: false
  tool_progress: off
  long_running_notifications: false
  background_process_notifications: off

# Keep a large live window. DeepSeek V4 Flash accepts one million tokens and
# Mistral Small 4 accepts 256k, so 200k is a portable normal target.
compression:
  enabled: true
  threshold: 0.82
  target_ratio: 0.62
  protect_last_n: 160
  protect_first_n: 4

memory:
  memory_enabled: true
  user_profile_enabled: false
  provider: openviking
  openviking:
    endpoint: http://openviking:1933
    account: tietopolitiikka
    user: telegram-core
    agent: tietopolitiikka-hermes
    recall_limit: 160
    recall_score_threshold: 0.16
    recall_max_injected_chars: 700000
    recall_timeout_seconds: 12.0
  nudge_interval: 12
  flush_min_turns: 6

platform_toolsets:
  telegram: [skills, memory]
  cli: [skills, memory]

telegram:
  enabled: true
  dm_policy: disabled
  group_policy: allowlist
  group_allowed_chats:
    - "${TELEGRAM_GROUP_ID}"
  allowed_chats:
    - "${TELEGRAM_GROUP_ID}"
  require_mention: false
  observe_unmentioned_group_messages: false
  free_response_chats:
    - "${TELEGRAM_GROUP_ID}"
  reply_to_mode: first
  unauthorized_dm_behavior: ignore
  disable_link_previews: false
  extra:
    base_url: "${TELEGRAM_API_BASE_URL}"
    local_mode: ${TELEGRAM_LOCAL_MODE}

gateway:
  session_inactivity_minutes: 240

tool_loop_guardrails:
  warnings_enabled: true
  hard_stop_enabled: true
  warn_after:
    exact_failure: 2
    same_tool_failure: 2
    idempotent_no_progress: 2
  hard_stop_after:
    exact_failure: 3
    same_tool_failure: 4
    idempotent_no_progress: 3
