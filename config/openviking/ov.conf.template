{
  "server": {
    "host": "0.0.0.0",
    "port": 1933,
    "auth_mode": "trusted",
    "root_api_key": "${OPENVIKING_API_KEY}"
  },
  "storage": {
    "workspace": "/data",
    "vectordb": {
      "name": "context",
      "backend": "local"
    },
    "agfs": {
      "backend": "local"
    }
  },
  "log": {
    "level": "INFO",
    "output": "stdout"
  },
  "embedding": {
    "max_concurrent": 2,
    "max_retries": 3,
    "text_source": "content_only",
    "max_input_tokens": 4096,
    "dense": {
      "provider": "ollama",
      "api_base": "http://ollama:11434/v1",
      "api_key": "local",
      "model": "bge-m3",
      "dimension": 1024,
      "input": "text"
    }
  },
  "vlm": {
    "provider": "openai",
    "api_base": "https://api.deepseek.com/v1",
    "api_key": "${DEEPSEEK_API_KEY}",
    "model": "${DEEPSEEK_MODEL}",
    "max_concurrent": 2
  }
}
