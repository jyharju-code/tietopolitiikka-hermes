{
  "storage": {
    "workspace": "/data",
    "vectordb": {
      "name": "context",
      "backend": "local"
    },
    "agfs": {
      "backend": "local"
    }
  },
  "log": {
    "level": "INFO",
    "output": "stdout"
  },
  "embedding": {
    "max_concurrent": 2,
    "max_retries": 3,
    "text_source": "content_only",
    "max_input_tokens": 4096,
    "dense": {
      "provider": "ollama",
      "api_base": "http://ollama:11434",
      "api_key": "local",
      "model": "nomic-embed-text",
      "dimension": 768,
      "input": "text"
    }
  },
  "vlm": {
    "provider": "openai",
    "api_base": "https://api.deepseek.com/v1",
    "api_key": "${DEEPSEEK_API_KEY}",
    "model": "${DEEPSEEK_MODEL}",
    "max_concurrent": 2
  },
  "memory": {
    "version": "v2",
    "agent_scope_mode": "user+agent"
  }
}
