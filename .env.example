# Copy to .env.runtime on the deployment host and set mode 600.

# Model provider. Pilot default is DeepSeek V4 Flash. Switch both values to
# mistral and mistral-small-latest after the Finnish A/B evaluation.
LLM_PROVIDER=deepseek
LLM_MODEL=deepseek-v4-flash
LLM_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_API_KEY=replace-me
MISTRAL_API_KEY=
MISTRAL_BASE_URL=https://api.eu.mistral.ai/v1

# Any OpenAI compatible endpoint: set LLM_PROVIDER=custom, LLM_MODEL to the
# vendor model id, and LLM_BASE_URL to the endpoint. Hermes derives the key
# env var from the host, so Nebius needs NEBIUS_API_KEY. Example:
#   LLM_PROVIDER=custom
#   LLM_MODEL=MiniMaxAI/MiniMax-M3
#   LLM_BASE_URL=https://api.studio.nebius.com/v1
NEBIUS_API_KEY=

OPENVIKING_API_KEY=replace-me
MEMORY_VLM_API_KEY=replace-me
MEMORY_VLM_API_BASE=https://api.deepseek.com/v1
MEMORY_VLM_MODEL=deepseek-v4-flash

# Fail closed until a dedicated bot is created and added as an administrator
# to the private Tietopolitiikka Hermes supergroup.
TELEGRAM_BOT_TOKEN=
TELEGRAM_GROUP_ID=
TELEGRAM_API_BASE_URL=

# Optional official local Bot API build for downloads over 20 MB.
TELEGRAM_LOCAL_API_ENABLED=false
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# The upstream Hermes dashboard is available only through the auth proxy.
HERMES_DASHBOARD_BASIC_AUTH_USERNAME=hermes-proxy
HERMES_DASHBOARD_BASIC_AUTH_PASSWORD=replace-with-random-secret
HERMES_DASHBOARD_PUBLIC_URL=https://tietopolitiikka.pages.dev

CLOUDFLARE_TUNNEL_ENABLED=false
CLOUDFLARE_TUNNEL_TOKEN=
# Lets the agent publish the draft site itself with publish-site. Create it in
# the Cloudflare dashboard with Account, Cloudflare Pages, Edit, restricted to
# the one account, and give it an expiry. Leave empty to keep publishing an
# operator step.
CLOUDFLARE_API_TOKEN=
CLOUDFLARED_IMAGE=cloudflare/cloudflared:2026.7.0

HERMES_IMAGE=nousresearch/hermes-agent@sha256:62ba776214e3df3d4c2b8ed21cc857fbaa918f6dc07089a528553bc26af300c0
OLLAMA_IMAGE=ollama/ollama@sha256:6345fbc18bd73a1e16404be681dbc6fd291a027cab43ed541abe78c4c81051b0

DATA_ROOT=/srv/tietopolitiikka-hermes
BACKUP_ROOT=/var/backups/tietopolitiikka-hermes
BACKUP_RETENTION_DAYS=14
